{
  "expo": {
    "name": "Noor",
    "slug": "noor",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "noor",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lotuzstudio.noor"
    },
    "android": {
      "package": "com.lotuzstudio.noor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-font", "expo-splash-screen"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://0z562xts-3000.euw.devtunnels.ms",
      "router": {}
    }
  }
}
